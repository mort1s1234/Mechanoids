<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Biotech</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName = "LargeMechGestator"]/recipes</xpath>
					<value>
						<li>APM_Aegis</li>
						<li>APM_Conqueror_AR</li>
						<li>APM_Conqueror_DMR</li>
						<li>APM_Conqueror_LMG</li>
						<li>APM_Lasher</li>
						<li>APM_Maul</li>
						<li>APM_Vassal</li>
						<li>APM_Ravager</li>
						<li>APM_Pulse</li>
						<li>APM_Mantis</li>
						<li>APM_Tinker</li>
						<li>APM_Siren</li>
						<li>APM_Ingestor</li>
						<li>APM_Dynamo</li>
						<li>APM_Frostivus</li>
						<li>APM_Dominus</li>
						<li>APM_Terminus</li>
						<li>APM_Celerus</li>
						<li>APM_Gazer</li>
					</value>
				</li>

								<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName = "MechGestator"]/recipes</xpath>
					<value>
						<li>APM_Haze</li>
					</value>
				</li>
				
				<li Class="PatchOperationAdd">
					<xpath>Defs/RecipeDef[defName = "ResurrectUltraheavyMech"]/fixedIngredientFilter/thingDefs</xpath>
					<value>
						<li>Corpse_APM_Mech_Ravager</li>
						<li>Corpse_APM_Mech_Ingestor</li>
						<li>Corpse_APM_Mech_Gazer</li>
					</value>
				</li>

				<li Class="PatchOperationAdd">
					<xpath>Defs/RecipeDef[defName = "ResurrectHeavyMech"]/fixedIngredientFilter/thingDefs</xpath>
					<value>
						<li>Corpse_APM_Mech_Aegis</li>
						<li>Corpse_APM_Mech_Maul</li>
						<li>Corpse_APM_Mech_Mantis</li>
						<li>Corpse_APM_Mech_Terminus</li>
						<li>Corpse_APM_Mech_Dynamo</li>
					</value>
				</li>

				<li Class="PatchOperationAdd">
					<xpath>Defs/RecipeDef[defName = "ResurrectMediumMech"]/fixedIngredientFilter/thingDefs</xpath>
					<value>
						<li>Corpse_APM_Mech_Conqueror_AR</li>
						<li>Corpse_APM_Mech_Conqueror_DMR</li>
						<li>Corpse_APM_Mech_Conqueror_LMG</li>
						<li>Corpse_APM_Mech_Lasher</li>
						<li>Corpse_APM_Mech_Pulse</li>
						<li>Corpse_APM_Mech_Vassal</li>
						<li>Corpse_APM_Mech_Tinker</li>
						<li>Corpse_APM_Mech_Siren</li>
						<li>Corpse_APM_Mech_Frostivus</li>
						<li>Corpse_APM_Mech_Dominus</li>
						<li>Corpse_APM_Mech_Celerus</li>
					</value>
				</li>

				<li Class="PatchOperationAdd">
					<xpath>Defs/RecipeDef[defName = "ResurrectLightMech"]/fixedIngredientFilter/thingDefs</xpath>
					<value>
						<li>Corpse_APM_Mech_Haze</li>
					</value>
				</li>

				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[@Name="MechGestatorBase"]/comps</xpath>
					<value>
						<li Class="CompProperties_AffectedByFacilities">
							<linkableFacilities>
								<li>APM_GestatorAmplifier</li>
							</linkableFacilities>
						</li>
					</value>
				</li>
				
			</operations>
		</match>
	</Operation>
</Patch>