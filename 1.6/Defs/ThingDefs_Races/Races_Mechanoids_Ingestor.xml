<Defs>
	<ThingDef Name="APM_Mech_Ingestor" ParentName="MechCentipede">
		<defName>APM_Mech_Ingestor</defName>
		<label>Ingestor</label>
		<description>While mechtech devices typically rely on internal power cells, provided electricity and incendiary fuel are still needed. The ingestor scourers the remains of battlefields for survivors to finish off and organic material including corpses, to automatically refine into chemfuel within its chassis.</description>
		<statBases>
			<MarketValue>1600</MarketValue>
			<MoveSpeed>1.9</MoveSpeed>
			<ArmorRating_Blunt>0.30</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.80</ArmorRating_Sharp>
			<ArmorRating_Heat>2.0</ArmorRating_Heat>
			<BandwidthCost MayRequire="Ludeon.RimWorld.Biotech">3</BandwidthCost>
			<MechEnergyLossPerHP MayRequire="Ludeon.Rimworld.Biotech">0.2</MechEnergyLossPerHP>
		</statBases>
		<tools Inherit="False">
			<li>
				<label>head</label>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>25</power>
				<cooldownTime>3.2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
