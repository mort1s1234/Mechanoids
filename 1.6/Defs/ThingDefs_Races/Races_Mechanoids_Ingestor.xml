			<renderTree>APM_RenderTree_Ingestor</renderTree>
			<baseHealthScale>4.32</baseHealthScale>
			<mechWeightClass>UltraHeavy</mechWeightClass>
			<mechEnabledWorkTypes>
				<li>APM_IngestorCorpseProcessing</li>
			</mechEnabledWorkTypes>
		</race>
		<butcherProducts>
			<Steel>45</Steel>
			<Plasteel>25</Plasteel>
		</butcherProducts>
		<modExtensions>
			<li Class="ApexMechanoids.DefModExtension_AnimationOnAttack">
				<animation>APM_EatingIngestorOneLoop</animation>
				<maneuver>Bite</maneuver>
