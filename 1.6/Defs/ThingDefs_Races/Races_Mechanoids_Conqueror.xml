	<AbilityDef>
		<defName>APM_UltimateSacrifice</defName>
		<label>ultimate sacrifice</label>
		<description>By rapidly performing complex aiming, movement and logic calculations until its processing units liquify from the heat, this mechanoid grants its nearby allies a temporary stat buff</description>
		<iconPath>UI/Sacrifice</iconPath>
		<cooldownTicksRange>900000</cooldownTicksRange>
		<targetRequired>false</targetRequired>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<canUseAoeToGetTargets>true</canUseAoeToGetTargets>
		<showCastingProgressBar>true</showCastingProgressBar>
		<warmupMote>APM_Mote_UltimateSacrifice_Pilar</warmupMote>
		<warmupEffecter>APM_UltitmateSacrifice</warmupEffecter>
		<statBases>
			<Ability_EffectRadius>12</Ability_EffectRadius>
			<Ability_Duration>150</Ability_Duration>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<warmupTime>5</warmupTime>
			<range>12.9</range>
			<drawAimPie>false</drawAimPie>
			<soundCast>APM_UltimateSacrifice</soundCast>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>APM_Hediff_UltimateSacrifice</hediffDef>
				<applyToSelf>false</applyToSelf>
				<ignoreSelf>true</ignoreSelf>
			</li>
			<li Class="ApexMechanoids.CompProperties_KillCaster">
				<destroy>false</destroy>
			</li>
			<li Class="ApexMechanoids.CompProperties_AbilityWarmupMote">
				<moteDef>APM_Mote_UltimateSacrifice_Wave</moteDef>
				<rotation>3</rotation>
			</li>
		</comps>
	</AbilityDef>

	<HediffDef>
		<defName>APM_Hediff_UltimateSacrifice</defName>
		<label>ultimate sacrifice</label>
		<description>Ultimate Sacrifice - One conqueror sacrifice himself to give a powerful buff to all allied conquerors in radius.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>True</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath" />
		</comps>
		<isBad>false</isBad>
		<stages>
			<li>
				<painFactor>0.7</painFactor>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.10</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>0.25</offset>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>
