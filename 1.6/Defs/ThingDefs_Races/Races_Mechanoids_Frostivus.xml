    	<allowInMechClusters>false</allowInMechClusters>
		<weaponTags>
			<!--<li>APM_FrostivusWeapon</li>-->
		</weaponTags>
		<weaponMoney>9999~9999</weaponMoney>
		<lifeStages>
			<li MayRequire="Ludeon.RimWorld.Biotech">
				<bodyGraphicData>
					<texPath>Things/Pawn/Mechanoid/Frostivus/Frostivus</texPath>
					<maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Frostivus/Mech_Frostivus</maskPath>
