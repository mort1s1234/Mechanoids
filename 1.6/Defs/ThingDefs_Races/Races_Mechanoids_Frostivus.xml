						<volume>(0.6, 0.8, 0.6)</volume>
						<offset>(0, 0, -0.4)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
			<li>
				<bodyGraphicData>
					<texPath>Things/Pawn/Mechanoid/Frostivus/FrostivusAncient</texPath>
					<maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Frostivus/Mech_Frostivus</maskPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>3</drawSize>
					<shadowData>
						<volume>(0.6, 0.8, 0.6)</volume>
						<offset>(0, 0, -0.4)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<techHediffsChance>1</techHediffsChance>
		<techHediffsMoney>9999~9999</techHediffsMoney>
		<controlGroupPortraitZoom>0.85</controlGroupPortraitZoom>
		<abilities>
			<li>APM_Ability_CryptoSwallow</li>
		</abilities>
	</PawnKindDef>
	
	<!-- Abilities -->
	<AbilityDef>
		<defName>APM_Ability_CryptoSwallow</defName>
		<label>Crypto Swallow</label>
		<description>Engulfs a living pawn or corpse, sealing it within an internal cryo-chamber. Preserves the target in suspended animation - halting decay and biological processes until released.</description>
		<iconPath>UI/Cryptoswallow</iconPath>
		<jobDef>CastAbilityOnThingMelee</jobDef>
		<stunTargetWhileCasting>True</stunTargetWhileCasting>
		<showPsycastEffects>False</showPsycastEffects>
		<displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted>
		<showWhenDrafted>false</showWhenDrafted>
		<cooldownTicksRange>3600~3600</cooldownTicksRange>
		<hostile>true</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<writeCombatLog>true</writeCombatLog>
		<aiCanUse>true</aiCanUse>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>False</drawAimPie>
			<range>-1</range>
			<warmupTime>1.0</warmupTime>
			<requireLineOfSight>True</requireLineOfSight>
			<soundCast>CryptosleepCasket_Eject</soundCast>
			<targetParams>
				<canTargetSelf>False</canTargetSelf>
				<canTargetPawns>True</canTargetPawns>
				<canTargetAnimals>False</canTargetAnimals>
				<canTargetMechs>False</canTargetMechs>
				<canTargetHumans>True</canTargetHumans>
				<canTargetSubhumans>false</canTargetSubhumans>
				<canTargetBuildings>False</canTargetBuildings>
				<canTargetLocations>False</canTargetLocations>
				<canTargetCorpses>True</canTargetCorpses>
				<neverTargetHostileFaction>True</neverTargetHostileFaction>
			</targetParams>
		</verbProperties>
		<statBases>
			<Ability_Duration>0</Ability_Duration>
			<Ability_EffectRadius>0</Ability_EffectRadius>
		</statBases>
		<comps>
			<li Class="ApexMechanoids.CompProperties_CryptoSwallow"></li>
		</comps>
	</AbilityDef>
</Defs>