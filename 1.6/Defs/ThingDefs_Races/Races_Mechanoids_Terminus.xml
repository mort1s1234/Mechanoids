	<AbilityDef>
		<defName>APM_TerminusOverdrive</defName>
		<label>overdrive</label>
		<description>Terminus diverts power inward and briefly enters an overdriven combat state. While active, it sheds its cape, strikes harder, recovers between swings faster and becomes harder to stagger.</description>
		<iconPath>UI/Overdrive</iconPath>
		<cooldownTicksRange>60000</cooldownTicksRange>
		<targetRequired>false</targetRequired>
		<hostile>false</hostile>
		<aiCanUse>true</aiCanUse>
		<showCastingProgressBar>true</showCastingProgressBar>
		<warmupMote>APM_Mote_TerminusOverdrive_BlueSacrificePilar</warmupMote>
		<warmupEffecter>APM_TerminusOverdrive_BlueSacrifice</warmupEffecter>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_Duration>30</Ability_Duration>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<warmupTime>1.1</warmupTime>
			<range>0.9</range>
			<drawAimPie>false</drawAimPie>
			<soundCast>APM_Overdrive</soundCast>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
				<canTargetPawns>false</canTargetPawns>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetAnimals>false</canTargetAnimals>
				<canTargetHumans>false</canTargetHumans>
				<canTargetLocations>false</canTargetLocations>
				<canTargetMechs>false</canTargetMechs>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>APM_Hediff_TerminusOverdrive</hediffDef>
				<applyToSelf>true</applyToSelf>
			</li>
			<li Class="ApexMechanoids.CompProperties_AbilityWarmupMote">
				<moteDef>APM_Mote_TerminusOverdrive_BlueSacrificeWave</moteDef>
				<rotation>3</rotation>
			</li>
			<li Class="ApexMechanoids.CompProperties_TerminusOverdriveCapeBurst">
				<moteDef>APM_Mote_TerminusCapeThrown</moteDef>
				<burstCount>1</burstCount>
				<spawnRadius>0.06</spawnRadius>
				<sideOffsetDistance>0.0</sideOffsetDistance>
				<verticalOffset>0.06</verticalOffset>
				<speedRange>2.8~3.2</speedRange>
				<angleOffsetRange>-10~10</angleOffsetRange>
			</li>
		</comps>
	</AbilityDef>

