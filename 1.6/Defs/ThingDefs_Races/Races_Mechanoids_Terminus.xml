	<HediffDef>
		<defName>APM_Hediff_TerminusOverdrive</defName>
		<label>overdrive</label>
		<description>Terminus is diverting a burst of power into direct combat performance, trading away its cape and restraint for a short window of overwhelming aggression.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.90, 0.83, 0.50)</defaultLabelColor>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>True</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath" />
			<li Class="ApexMechanoids.HediffCompProperties_TerminusOverdriveCapeVisibility" />
		</comps>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>0.25</offset>
					</li>
				</capMods>
				<statFactors>
					<MeleeDamageFactor>1.4</MeleeDamageFactor>
					<MeleeCooldownFactor>0.65</MeleeCooldownFactor>
					<StaggerDurationFactor>0.35</StaggerDurationFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<AbilityDef>
		<defName>SeveringEdge</defName>
