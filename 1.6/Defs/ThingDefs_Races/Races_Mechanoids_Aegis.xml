<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="HeavyMechanoid">
		<defName>APM_Mech_Aegis</defName>
		<label>Aegis</label>
		<description>The Aegis is a mighty mechanoid that sacrifices offensive capabilities for defensive mastery. The phrase 'The best defense is a good offense' rings true with the Aegis' dual shields.</description>
		<statBases>
			<MoveSpeed>1.9</MoveSpeed>
			<ArmorRating_Blunt>0.5</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
			<ArmorRating_Heat>2.0</ArmorRating_Heat>
			<MarketValue>1200</MarketValue>
			<BandwidthCost MayRequire="Ludeon.RimWorld.Biotech">4</BandwidthCost>
			<MechEnergyLossPerHP>0.2</MechEnergyLossPerHP>
			<WorkSpeedGlobal>1.5</WorkSpeedGlobal>
		</statBases>
		<race>
			<body>APM_Aegis</body>
			<baseBodySize>3.5</baseBodySize>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseHealthScale>3.82</baseHealthScale>
			<mechWeightClass>Heavy</mechWeightClass>
			<renderTree>APM_RenderTree_Aegis</renderTree>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>Pawn_Mech_Tunneler_Wounded</soundWounded>
					<soundDeath>Pawn_Mech_Tunneler_Death</soundDeath>
					<soundCall>Pawn_Mech_Tunneler_Call</soundCall>
				</li>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>100</minAge>
					<soundWounded>Pawn_Mech_Tunneler_Wounded</soundWounded>
					<soundDeath>Pawn_Mech_Tunneler_Death</soundDeath>
					<soundCall>Pawn_Mech_Tunneler_Call</soundCall>
				</li>
			</lifeStageAges>
			<bulletStaggerEffecterDef>TunnelerSlowedDown</bulletStaggerEffecterDef>
			<detritusLeavings>
				<li>
					<def>ChunkMechanoidSlag</def>
					<texOverrideIndex>0</texOverrideIndex>
					<spawnChance>0.5</spawnChance>
				</li>
				<li>
					<def>ChunkMechanoidSlag</def>
					<texOverrideIndex>3</texOverrideIndex>
					<spawnChance>0.5</spawnChance>
				</li>
				<li>
					<def>ChunkMechanoidSlag</def>
					<texOverrideIndex>1</texOverrideIndex>
					<spawnChance>0.5</spawnChance>
				</li>
			</detritusLeavings>
		</race>
		<tools>
			<li>
				<label>left shield</label>
				<labelNoLocation>shield</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Scratch</li>
				</capacities>
				<power>22</power>
				<cooldownTime>2.9</cooldownTime>
				<linkedBodyPartsGroup>APM_LeftAegisShield</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
			<li>
				<label>right shield</label>
				<labelNoLocation>shield</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Scratch</li>
				</capacities>
				<power>22</power>
				<cooldownTime>2.9</cooldownTime>
				<linkedBodyPartsGroup>APM_RightAegisShield</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<modExtensions>
			<li Class="ApexMechanoids.ModExtension_Aegis">
				<shieldPart>APM_AegisShield</shieldPart>
				<leftShieldGroup>APM_LeftAegisShield</leftShieldGroup>
				<rightShieldGroup>APM_RightAegisShield</rightShieldGroup>
				<!-- Minimum time in seconds of peace before regeneration starts after damage -->
				<regenerationDelaySeconds>60</regenerationDelaySeconds>
				<!-- How often to regenerate, in seconds. Uses CompTickRare, so values below ~4.16s won't work. -->
				<regenerationIntervalSeconds>30</regenerationIntervalSeconds>
				<!-- Shield HP restored per regeneration step (kept very slow) -->
				<regenerationHPPerStep>1</regenerationHPPerStep>
				<!-- Chance a side attack is caught by that side's shield -->
				<sideDamageChance>0.2</sideDamageChance>
				<!-- Extra mech energy drained per shield HP restored during repair (x MechEnergyLossPerHP) -->
				<repairEnergyCostMultiplier>3</repairEnergyCostMultiplier>
			</li>
		</modExtensions>
		<butcherProducts>
			<Steel>40</Steel>
			<Plasteel>15</Plasteel>
		</butcherProducts>
	</ThingDef>

	<PawnKindDef ParentName="HeavyMechanoidKind">
		<defName>APM_Mech_Aegis</defName>
		<label>Aegis</label>
		<race>APM_Mech_Aegis</race>
		<allowInMechClusters>true</allowInMechClusters>
		<combatPower>400</combatPower>
		<weaponTags>
			<li>APM_AegisShield</li>
		</weaponTags>
		<weaponMoney>9999~9999</weaponMoney>
		<lifeStages>
			<li MayRequire="Ludeon.RimWorld.Biotech">
				<bodyGraphicData>
					<texPath>Things/Pawn/Mechanoid/Aegis/Mechanoid/Aegis</texPath>
					<maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Aegis/Mechanoid/Mech_Aegis</maskPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>2.5</drawSize>
					<shadowData>
						<volume>(0.8, 1.5, 0.8)</volume>
						<offset>(0, 0, -0.6)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
			<li>
				<bodyGraphicData>
					<texPath>Things/Pawn/Mechanoid/Aegis/Mechanoid/AegisAncient</texPath>
					<maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Aegis/Mechanoid/Mech_Aegis</maskPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>2.5</drawSize>
					<shadowData>
						<volume>(0.8, 1.5, 0.8)</volume>
						<offset>(0, 0, -0.6)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<techHediffsChance MayRequire="Ludeon.RimWorld.Biotech">1</techHediffsChance>
		<controlGroupPortraitZoom>0.9</controlGroupPortraitZoom>
		<abilities>
			<li>APM_ShieldCharge</li>
		</abilities>
	</PawnKindDef>
</Defs>