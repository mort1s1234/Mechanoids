	<AbilityDef>
		<defName>APM_PressTheAttack</defName>
		<label>Press The Attack</label>
		<description>The Dominus emits a psychic pulse that influences nearby allies to ignore pain, move faster and stay in high spirits.</description>
		<iconPath>UI/PressTheAttack</iconPath>
		<cooldownTicksRange>180000</cooldownTicksRange>
		<targetRequired>false</targetRequired>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<showCastingProgressBar>true</showCastingProgressBar>
		<statBases>
			<Ability_EffectRadius>12</Ability_EffectRadius>
			<Ability_Duration>150</Ability_Duration>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<warmupTime>1</warmupTime>
			<soundCast>APM_PressTheAttack_Cast</soundCast>
			<range>12.9</range>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="ApexMechanoids.CompProperties_AbilitySteelDiscipline">
				<radius>12</radius>
				<buffHediff>APM_Hediff_PressTheAttack</buffHediff>
				<buffHediffBoss>APM_Hediff_PressTheAttack_Boss</buffHediffBoss>
			</li>
		</comps>
	</AbilityDef>

	<HediffDef>
		<defName>APM_Hediff_PressTheAttack</defName>
		<label>Psionic rush</label>
		<description>A psionic wave directly stimulating the brain's neural pathways. It temporarily numbs pain receptors and forces an intense surge of adrenaline, allowing the subject to move significantly faster and disregard physical trauma. The effect is highly potent but short-lived.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>True</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath" />
		</comps>
		<isBad>false</isBad>
		<stages>
			<li>
				<painFactor>0.85</painFactor>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.10</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>0.15</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<renderNodeProperties>
			<li>
				<workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
				<texPath>Things/Mote/PressTheAttack/Halo</texPath>
				<parentTagDef>Head</parentTagDef>
				<pawnType>HumanlikeOnly</pawnType>
				<color>(68, 150, 215)</color>
				<drawData>
					<scale>0.7</scale>
					<scaleOffsetByBodySize>true</scaleOffsetByBodySize>
					<defaultData>
						<layer>92</layer>
						<offset>(0,0,0.5)</offset>
					</defaultData>
				</drawData>
			</li>
			<li>
				<workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
				<texPath>Things/Mote/PressTheAttack/Halo</texPath>
				<pawnType>NonHumanlikeOnly</pawnType>
				<color>(68, 150, 215)</color>
				<drawData>
					<scale>0.7</scale>
					<scaleOffsetByBodySize>true</scaleOffsetByBodySize>
					<defaultData>
						<layer>92</layer>
						<offset>(0,0,0.9)</offset>
					</defaultData>
				</drawData>
			</li>
			<li Class="ApexMechanoids.PawnRenderNodeProperties_Animated">
				<nodeClass>ApexMechanoids.PawnRenderNode_RandomAnimated</nodeClass>
				<workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
				<texPath>Things/Mote/PressTheAttack/Wings</texPath>
				<parentTagDef>Body</parentTagDef>
				<pawnType>Any</pawnType>
				<color>(68, 150, 215)</color>
				<texPaths>
					<li>Things/Mote/PressTheAttack/Wings/WingsA</li>
					<li>Things/Mote/PressTheAttack/Wings/WingsB</li>
					<li>Things/Mote/PressTheAttack/Wings/WingsC</li>
				</texPaths>
				<ticksPerTexture>3</ticksPerTexture>
				<drawData>
					<scale>2.3</scale>
					<defaultData>
						<layer>-6</layer>
						<offset>(0,0,0)</offset>
					</defaultData>
				</drawData>
			</li>
		</renderNodeProperties>
	</HediffDef>

