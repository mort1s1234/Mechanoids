<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="MoteBase">
		<defName>APM_Mote_Whip</defName>
		<thingClass>ApexMechanoids.Mote_Whip</thingClass>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<mote>
			<fadeInTime>0.09</fadeInTime>
			<fadeOutTime>0.3</fadeOutTime>
			<solidTime>0.1</solidTime>
			<rotateTowardsTarget>True</rotateTowardsTarget>
			<scaleToConnectTargets>true</scaleToConnectTargets>
		</mote>
		<graphicData>
			<texPath>Things/Mote/WhipEffects/Whip_Animation1</texPath>
			<graphicClass>Graphic_Mote</graphicClass>
			<shaderType>Mote</shaderType>
			<drawSize>(3.5, 0.7)</drawSize>
		</graphicData>
	</ThingDef>

	<ThingDef ParentName="BaseGun">
		<defName>APM_Weapon_MechWhip</defName>
		<label>mech whip</label>
		<description>The mech whip can deal heavy damage and stun multiple targets in close proximity to the user. It appears the mechhive views sentient organic life akin to how we view cattle, and treats us as such.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/Mech_Whip</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(0.8, 0.8)</drawSize>
		</graphicData>
		<soundInteract>Interact_ChargeRifle</soundInteract>
		<destroyOnDrop>true</destroyOnDrop>
		<tradeability>None</tradeability>
		<statBases>
			<WorkToMake>30000</WorkToMake>
			<Mass>1.5</Mass>
			<AccuracyTouch>0.40</AccuracyTouch>
			<AccuracyShort>0.48</AccuracyShort>
			<AccuracyMedium>0.35</AccuracyMedium>
			<AccuracyLong>0.26</AccuracyLong>
			<RangedWeapon_Cooldown>2.6</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>APM_MechanoidWhip</li>
		</weaponTags>
		<verbs>
			<li>
				<verbClass>ApexMechanoids.Verb_Whip</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<warmupTime>0</warmupTime>
				<range>6.9</range>
				<ticksBetweenBurstShots>4</ticksBetweenBurstShots>
				<soundCast>APM_Whip</soundCast>
				<muzzleFlashScale>0</muzzleFlashScale>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
			</li>
		</verbs>
		<tools>
			<li>
				<label>edge</label>
				<capacities>
					<li>APM_Whip</li>
				</capacities>
				<power>15</power>
				<cooldownTime>2.6</cooldownTime>
				<extraMeleeDamages>
				<li>
					<def>EMP</def>
					<chance>10</chance>
					<amount>15</amount>
				</li>
				</extraMeleeDamages>
			</li>
		</tools>
	</ThingDef>

	<ManeuverDef>
		<defName>APM_Whip</defName>
		<requiredCapacity>APM_Whip</requiredCapacity>
		<verb>
			<verbClass>ApexMechanoids.Verb_MeleeWhip</verbClass>
			<meleeDamageDef>Cut</meleeDamageDef>
		</verb>
		<logEntryDef>MeleeAttack</logEntryDef>
		<combatLogRulesHit>Maneuver_Slash_MeleeHit</combatLogRulesHit>
		<combatLogRulesDeflect>Maneuver_Slash_MeleeDeflect</combatLogRulesDeflect>
		<combatLogRulesMiss>Maneuver_Slash_MeleeMiss</combatLogRulesMiss>
		<combatLogRulesDodge>Maneuver_Slash_MeleeDodge</combatLogRulesDodge>
	</ManeuverDef>

	<ToolCapacityDef>
		<defName>APM_Whip</defName>
		<label>whip</label>
	</ToolCapacityDef>
</Defs>