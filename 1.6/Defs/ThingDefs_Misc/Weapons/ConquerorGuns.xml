<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="BaseGun" Name="APM_Gun_Conqueror_AR">
		<defName>APM_Gun_Conqueror_AR</defName>
		<label>charge blaster rifle</label>
		<description>A general-purpose pulse-charged assault rifle designed for mid-range engagements. Highly reliable in all combat scenarios with a balanced rate of fire and precision.</description>
		<techLevel>Spacer</techLevel>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/ConquerorAR</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_ChargeRifle</soundInteract>
		<destroyOnDrop>true</destroyOnDrop>
		<tradeability>None</tradeability>
		<statBases>
			<WorkToMake>45000</WorkToMake>
			<Mass>4.2</Mass>
			<AccuracyTouch>0.60</AccuracyTouch>
			<AccuracyShort>0.75</AccuracyShort>
			<AccuracyMedium>0.70</AccuracyMedium>
			<AccuracyLong>0.55</AccuracyLong>
			<RangedWeapon_Cooldown>1.50</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>APM_WeaponConquerorAR</li>
		</weaponTags>
		<weaponClasses>
			<li>RangedLight</li>
		</weaponClasses>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>Bullet_ChargeRifle</defaultProjectile>
				<warmupTime>0.9</warmupTime>
				<range>25.9</range>
				<ticksBetweenBurstShots>8</ticksBetweenBurstShots>
				<burstShotCount>3</burstShotCount>
				<soundCast>Shot_ChargeRifle</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
	</ThingDef>

