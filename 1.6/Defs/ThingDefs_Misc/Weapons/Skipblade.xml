				</capacities>
				<power>22</power>
				<cooldownTime>1.35</cooldownTime>
				<armorPenetration>0.85</armorPenetration>
			</li>
		</tools>
		<comps>
			<li Class="ApexMechanoids.CompProperties_AbilityGranter">
