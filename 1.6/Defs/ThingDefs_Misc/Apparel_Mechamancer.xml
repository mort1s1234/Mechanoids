<Defs>
	<ThingDef ParentName="ApparelBase">
		<defName>APM_Apparel_MechamancerSuit</defName>
		<label>mechamancer suit</label>
		<description>A power-assisted armor suit packed with mechanitor-assistance gear. The mechmancer suit dramatically amplifies a mechanitor's bandwidth, providing a personal energy shield and damage resistance comparable to dedicated power armor.</description>
		<techLevel>Spacer</techLevel>
		<thingCategories>
      		<li>ApparelArmor</li>
   		</thingCategories>
		<tradeTags>
	<li>ExoticMisc</li>
	<li>Clothing</li>
    <li>HiTechArmor</li>
    <li>Armor</li>
    	</tradeTags>
    <generateCommonality>2</generateCommonality>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/MechamancerSuit/MechJuggernaut_icon</texPath><!-- make an icon -->
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<drawSize>(0.85, 0.85)</drawSize>
		</graphicData>
		<statBases>
		    <WorkToMake>60000</WorkToMake>
      		<MaxHitPoints>400</MaxHitPoints>
      		<Mass>12</Mass>
			<ArmorRating_Sharp>1.20</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.57</ArmorRating_Blunt>
			<ArmorRating_Heat>0.68</ArmorRating_Heat>
			<Insulation_Cold>55</Insulation_Cold>
			<Insulation_Heat>38</Insulation_Heat>
			<EquipDelay>20</EquipDelay>
			<EnergyShieldRechargeRate>0.02</EnergyShieldRechargeRate>
			<EnergyShieldEnergyMax>0.4</EnergyShieldEnergyMax>
			<EnergyShieldRechargeRate MayRequire="Ludeon.RimWorld.Royalty">0.12</EnergyShieldRechargeRate>
			<EnergyShieldEnergyMax MayRequire="Ludeon.RimWorld.Royalty">1.2</EnergyShieldEnergyMax>
		</statBases>
    	<costList>
      		<ComponentSpacer>8</ComponentSpacer>
      		<Plasteel>180</Plasteel>
			<Steel>40</Steel>
      		<Uranium>20</Uranium>
      		<APM_PsionicChip>2</APM_PsionicChip>
      		<APM_ExtraChip>2</APM_ExtraChip>
    	</costList>
		<comps>
			<li Class="CompProperties_Shield" MayRequire="Ludeon.RimWorld.Royalty">
				<blocksRangedWeapons>false</blocksRangedWeapons>
			</li>
		</comps>
		<equippedStatOffsets>
			<MechControlGroups>2</MechControlGroups>
			<MechBandwidth>24</MechBandwidth>
			<PainShockThreshold>0.05</PainShockThreshold>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.4</VacuumResistance>
		</equippedStatOffsets>
		<apparel>
		<bodyPartGroups>
        	<li>Torso</li>
        	<li>Neck</li>
        	<li>Shoulders</li>
        	<li>Arms</li>
        	<li>Legs</li>
      	</bodyPartGroups>
		<layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
			<tags>
				<li>RoyalTier7</li>
				<li>APM_Mechamancer</li>
			</tags>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/MechamancerSuit/MechJuggernaut</wornGraphicPath>
      <defaultOutfitTags>
        <li>Soldier</li>
        <li>Spacefarer</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
      <forceEyesVisibleForRotations>
        <li>1</li>
        <li>2</li>
        <li>3</li>
      </forceEyesVisibleForRotations>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9,1)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.33,0.33,0.33,1)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65,1)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(0.3,0.3,0.3,1)</min>
          <max>(0.5,0.5,0.5,1)</max>
        </li>
      </options>
    </colorGenerator>
    <comps>
      <li Class="CompProperties_Biocodable"/>
    </comps>
    <thingSetMakerTags>
      <li>RewardStandardHighFreq</li>
    </thingSetMakerTags>
		<tradeability>Sellable</tradeability>
	</ThingDef>

	
