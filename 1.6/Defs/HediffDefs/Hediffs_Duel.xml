<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef>
		<defName>APM_InDuel</defName>
		<label>in duel</label>
		<hediffClass>HediffWithComps</hediffClass>
		<description>Locked in a duel. A shield arena has been conjured around both combatants, blocking all ranged attacks and abilities for the duration. Incoming damage is greatly increased to force decisive action — the duel is meant to end quickly and brutally. All healing is suppressed within the arena, save for what little may be drawn from striking the enemy. Should either combatant be downed or slain, the survivor claims victory. Should time expire with both still standing, the duel ends in a draw — and both pay the price.</description>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<IncomingDamageFactor>1.75</IncomingDamageFactor>
					<MeleeCooldownFactor>0.7</MeleeCooldownFactor>
				</statFactors>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>1200</disappearsAfterTicks>
				<!--The same as duel mental state-->
				<showRemainingTime>True</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath" />
		</comps>
	</HediffDef>

