<?xml version="1.0" encoding="utf-8"?>
<Defs>


	<!-- MechCommandCasket Parent -->
	<ThingDef Name="APM_MechCommandCasket_Base" ParentName="BuildingBase" Abstract="True">
		<tickerType>Normal</tickerType>
		<thingClass>ApexMechanoids.Building_MechCommandCasket</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<thingCategories>
			<li>BuildingsMisc</li>
		</thingCategories>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<minifiedDef>MinifiedThing</minifiedDef>
		<canOverlapZones>false</canOverlapZones>
		<pathCost>42</pathCost>
		<blockWind>true</blockWind>
		<fillPercent>0.5</fillPercent>
		<building>
			<paintable>false</paintable>
			<destroySound>BuildingDestroyed_Metal_Big</destroySound>
			<buildingTags>
				<li>Biotech</li>
			</buildingTags>
			<ai_chillDestination>false</ai_chillDestination>
			<haulToContainerDuration>120</haulToContainerDuration>
			<fixedStorageSettings>
				<filter>
					<categories>
						<li>Foods</li>
					</categories>
					<specialFiltersToDisallow>
						<li>AllowPlantFood</li>
					</specialFiltersToDisallow>
				</filter>
			</fixedStorageSettings>
			<defaultStorageSettings>
				<filter>
					<categories>
						<li>Foods</li>
					</categories>
					<disallowedCategories>
						<li>EggsFertilized</li>
					</disallowedCategories>
					<disallowedThingDefs>
						<li>InsectJelly</li>
						<li>MealLavish</li>
						<li>MealLavish_Veg</li>
						<li>MealLavish_Meat</li>
						<li>HemogenPack</li>
						<li>Chocolate</li>
					</disallowedThingDefs>
				</filter>
			  </defaultStorageSettings>
		</building>
		<inspectorTabs>
			<li>ITab_BiosculpterNutritionStorage</li>
		</inspectorTabs>
		<containedPawnsSelectable>true</containedPawnsSelectable>
		<designationCategory>Biotech</designationCategory>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>3200</WorkToBuild>
			<Mass>100</Mass>
			<Flammability>0.6</Flammability>
		</statBases>
		<size>(3,2)</size>
		<rotatable>true</rotatable>
		<defaultPlacingRot>South</defaultPlacingRot>
		<interactionCellOffset>(0,0,2)</interactionCellOffset>
		<hasInteractionCell>true</hasInteractionCell>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<costList>
			<Steel>250</Steel>
			<Plasteel>80</Plasteel>
			<ComponentIndustrial>4</ComponentIndustrial>
			<ComponentSpacer>8</ComponentSpacer>
			<SubcoreHigh>1</SubcoreHigh>
			<APM_PsionicChip>1</APM_PsionicChip>
		</costList>
		<constructionSkillPrerequisite>5</constructionSkillPrerequisite>
		<comps>
			<li Class="CompProperties_Flickable" />
			<li Class="CompProperties_Breakdownable" />
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>APM_CasketBandwidthAmplifier</li>
				</linkableFacilities>
			</li>			
		</comps>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
    </ThingDef>


	<ThingDef ParentName="APM_MechCommandCasket_Base">
		<defName>APM_MechCommandCasket</defName>
		<label>mech command casket</label>
		<description>The mech command casket is a fusion of mechlink and cryptosleep casket technology, allowing the enclosed user to control their mechanoids from the relative safety of the casket. The signal boosting capabilities of this machine allow the mechanitor to control their mechs even when world tiles away from them.</description>
		<graphicData>
			<texPath>Things/Building/MechCommandCasket/MechCommandCasket</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,2)</drawSize>
			<drawOffset>(0,0,0)</drawOffset>
			<shadowData>
				<volume>(2.70, 1, 1.70)</volume>
				<offset>(0, 0, 0)</offset>
			</shadowData>
		</graphicData>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>3200</WorkToBuild>
			<Mass>100</Mass>
			<Flammability>0.6</Flammability>
		</statBases>
		<size>(3,2)</size>
		<costList>
			<Steel>250</Steel>
            <Plasteel>80</Plasteel>
            <ComponentIndustrial>4</ComponentIndustrial>
            <ComponentSpacer>8</ComponentSpacer>
            <SubcoreHigh>1</SubcoreHigh>
            <APM_PsionicChip>1</APM_PsionicChip>
		</costList>
		<constructionSkillPrerequisite>5</constructionSkillPrerequisite>
		<researchPrerequisites>
			<li>ApexMechtech</li>
		</researchPrerequisites>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<shortCircuitInRain>true</shortCircuitInRain>
				<basePowerConsumption>1000</basePowerConsumption>
				<idlePowerDraw>80</idlePowerDraw>
			</li>
			<li Class="ApexMechanoids.CompProperties_RemoteMechCasketAbilities">
				<actionspeed>1.0</actionspeed>
				<repairExp>0.05</repairExp>		<!-- same as remote repair implant -->
				<repairCostsEnergy>true</repairCostsEnergy>	<!-- same as remote repair implant -->
				<Shieldcooldown>300</Shieldcooldown>	<!-- same as remote shield implant -->
				<textpath_Connect>UI/Gizmos/APM_ConnectToMech</textpath_Connect>
				<textpath_Disconnect>UI/Gizmos/APM_DisconnectFromMech</textpath_Disconnect>
				<textpath_Repair>UI/Gizmos/APM_Repair</textpath_Repair>
				<textpath_Shield>UI/Gizmos/APM_ShieldMech</textpath_Shield>
				<textpath_ShieldCooldown>UI/Gizmos/APM_ShieldMechCooldown</textpath_ShieldCooldown>
				<labelShort>Casket</labelShort>
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
	</ThingDef>


	<HediffDef>
		<defName>APM_MechCommandCasketBoost</defName>
		<label>mech command casket boost</label>
		<description>PLACEHOLDER DESCRIPTION! This mechanitors bandwidth is increased while inside the command casket.</description>
		<hediffClass>ApexMechanoids.Hediff_CommandCasketBoost</hediffClass>
		<defaultLabelColor>(0.52, 1, 0.95)</defaultLabelColor>
		<maxSeverity>100</maxSeverity>
		<isBad>false</isBad>
	</HediffDef>


	<ThingDef ParentName="BuildingBase">
		<defName>APM_CasketBandwidthAmplifier</defName>
		<label>mech casket bandwidth amplifier</label>
		<description>PLACEHOLDER DESCRIPTION! It increases the bandwidth of any mechanitor inside a command casket it is placed adjacent to.</description>
		<tickerType>Long</tickerType>
		<graphicData>
			<texPath>Things/Building/GestatorAmplifier/Amplifier</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2,2)</drawSize>
			<drawOffset>(0,0,0)</drawOffset>
			<shadowData>
				<volume>(1.65, 0.75, 1)</volume>
				<offset>(0.15, 0, 0)</offset>
			</shadowData>
		</graphicData>
		<thingCategories>
			<li>BuildingsMisc</li>
		</thingCategories>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<minifiedDef>MinifiedThing</minifiedDef>
		<canOverlapZones>false</canOverlapZones>
		<pathCost>42</pathCost>
		<blockWind>true</blockWind>
		<fillPercent>0.5</fillPercent>
		<building>
			<paintable>false</paintable>
			<destroySound>BuildingDestroyed_Metal_Small</destroySound>
			<buildingTags>
				<li>Biotech</li>
			</buildingTags>
			<ai_chillDestination>false</ai_chillDestination>
		</building>
		<designationCategory>Biotech</designationCategory>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<WorkToBuild>1000</WorkToBuild>
			<Mass>70</Mass>
			<Flammability>0.5</Flammability>
		</statBases>
		<size>(2,1)</size>
		<rotatable>true</rotatable>
		<costList>
			<Steel>250</Steel>
			<ComponentIndustrial>2</ComponentIndustrial>
			<APM_OcularChip>1</APM_OcularChip>
		</costList>
		<constructionSkillPrerequisite>5</constructionSkillPrerequisite>
		<researchPrerequisites>
			<li>AdvancedMechtech</li>
		</researchPrerequisites>
		<comps>
			<li Class="CompProperties_Facility">
				<statOffsets>
					<APM_CasketBandwidth>6</APM_CasketBandwidth>
				</statOffsets>
				<maxSimultaneous>2</maxSimultaneous>
				<mustBePlacedAdjacent>true</mustBePlacedAdjacent>	<!-- 2 is adjacent  -->
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
		</placeWorkers>
	</ThingDef>



</Defs>