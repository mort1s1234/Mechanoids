	<HediffDef>
		<defName>APM_MechCommandCasketBoost</defName>
		<label>mech command casket boost</label>
		<description>This mechanitors bandwidth is increased while inside the command casket.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.52, 1, 0.95)</defaultLabelColor>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>90</disappearsAfterTicks>	<!-- so it gets removed when the pawn leaves -->
				<showRemainingTime>false</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<MechBandwidth>6</MechBandwidth>
					<!-- <WorkSpeedGlobalOffsetMech>0.3</WorkSpeedGlobalOffsetMech> -->
					<!-- <MechRepairSpeed>0.3</MechRepairSpeed> -->
					<!-- <MechFormingSpeed>0.45</MechFormingSpeed>  -->
				</statOffsets>
				<statFactors>
					<!-- <MechBandwidth>1.3</MechBandwidth> -->
				</statFactors>
			</li>
		</stages>
		<isBad>false</isBad>
	</HediffDef>



</Defs>
