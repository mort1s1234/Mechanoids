<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="BuildingBase">
		<defName>APM_Building_ToxicPurifier</defName>
		<label>purifier station</label>
		<description>The pollution reclaimer is an imperfect solution to a disastrous problem. It cleans pollution from a large area around it in addition to vaporizing toxic wastepacks. Its function is imperfect due to the drastic rate it runs at and It has a constant chance to cause several severe ecological events such as the following: Releasing toxic waste into the air, causing a toxic downpour, generating a toxic smog in the local area up to several world tiles around where it is placed and spoiling relations over time with local neighboring factions. While it works well, ecologists and mechanitors alike still argue whether the side effects are worth the hassle.</description>
		<drawerType>MapMeshAndRealTime</drawerType>
		<tickerType>Normal</tickerType>
		<graphicData>
			<texPath>Things/Building/PowerPlant/PowerPlant</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(7,7)</drawSize>
			<drawOffset>(0,0,1)</drawOffset>
			<shadowData>
				<volume>(4, 3, 4)</volume>
				<offset>(0, 0, 0)</offset>
			</shadowData>
		</graphicData>
		<thingCategories>
			<li>BuildingsMisc</li>
		</thingCategories>
		<uiIconPath>Things/Building/PowerPlant/PowerPlantUI</uiIconPath>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<minifiedDef>MinifiedThing</minifiedDef>
		<canOverlapZones>false</canOverlapZones>
		<pathCost>42</pathCost>
		<blockWind>true</blockWind>
		<fillPercent>0.5</fillPercent>
		<building>
			<buildingTags>
				<li>Biotech</li>
			</buildingTags>
			<ai_chillDestination>false</ai_chillDestination>
		</building>
		<designationCategory>Biotech</designationCategory>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>30000</WorkToBuild>
			<Mass>800</Mass>
			<Flammability>0.5</Flammability>
		</statBases>
		<size>(5,5)</size>
		<costList>
			<Steel>450</Steel>
			<Plasteel>100</Plasteel>
			<APM_PsyfluxChip>1</APM_PsyfluxChip>
		</costList>
		<constructionSkillPrerequisite>12</constructionSkillPrerequisite>
		<specialDisplayRadius>40</specialDisplayRadius>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>4000</basePowerConsumption>
			</li>
			<li Class="ApexMechanoids.CompProperties_ToxicPurifier">
				<toxicPerTileCleaned>0.005</toxicPerTileCleaned>
				<interval>2500</interval>
				<radius>40</radius>
				<tileToUnpollutePerTrigger>10</tileToUnpollutePerTrigger>
				<isCleanRandomTileInMap>true</isCleanRandomTileInMap>
				<pumpEffecterDef>PollutionPumped</pumpEffecterDef>
				<effecterOffset>(0,0,4)</effecterOffset>
				<effecterVectorOffset>(0,0,2)</effecterVectorOffset>
				<conditionDef>APM_Toxicity</conditionDef>
			</li>
		</comps>
		<researchPrerequisites>
			<li>AdvancedMechtech</li>
		</researchPrerequisites>
	</ThingDef>

	<GameConditionDef>
		<defName>APM_Toxicity</defName>
		<conditionClass>ApexMechanoids.GameCondition_ToxicPurifier</conditionClass>
		<label>toxicity level</label>
		<description>toxic level in local atmosphere.</description>
		<canBePermanent>true</canBePermanent>
		<!-- <displayOnUI>false</displayOnUI> -->
		<modExtensions>
			<li Class="ApexMechanoids.DefModExtension_ToxicPurifier">
				<maxValue>1.00</maxValue> <!-- 1.00 translate to 100% -->
				<!-- if toxicityUnit is not omitted, it will be show as ie. toxicity level (1.0Psi) -->
				<!-- <toxicityUnit>Psi</toxicityUnit> -->
				<toxicRecoveryPerDay>-0.25</toxicRecoveryPerDay> <!-- 25% -->
				<toxicLevelToStartSpreading>0.5</toxicLevelToStartSpreading> <!-- 50% -->
				<toxicLevelToAffectRelation>0.75</toxicLevelToAffectRelation> <!-- 75% -->
				<goodWillChangePerDayAboveThreshold>-1</goodWillChangePerDayAboveThreshold>
				<pollutionChangeOnNeighborsTile>0.01</pollutionChangeOnNeighborsTile> <!-- 1% per day, per tiles -->
				<tileRadius>10</tileRadius>
				<chanceForToxicFallout>0.05</chanceForToxicFallout> <!-- 5% -->
			</li>
		</modExtensions>
	</GameConditionDef>

</Defs>